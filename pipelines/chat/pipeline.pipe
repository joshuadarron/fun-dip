    {
      "id": "tool_pipe_1",
      "provider": "tool_pipe",
      "name": "Profile Pipeline Tool",
      "config": {
        "apikey": "MYAPIKEY",
        "pipe": "/Users/dylansavage/Desktop/RocketRide-Project/fun-dip/pipelines/profile/pipeline.pipe",
        "return_type": "text",
        "tool_description": "Invoke the Fundip profile pipeline to read or conversationally edit the user's startup profile in Ghost. Input shape: { profile_id: string, mode: 'create' | 'update' | 'read', facts?: Array<{ field: string, value: unknown, source: 'chat' }>, context?: string }. Use mode='update' with facts whenever the current user message states a persistable fact about the startup (stage, location, market, looking_for, goals, or narrative color). Use mode='read' to warm context with the latest profile_summary when you need it. Returns { status, profile_id, delta: { fields_updated, fields_added, narrative_appended }, profile_summary }. This tool only writes to 'profiles' and 'profile_narratives'. Do not use it to match programs, scrape the web, or submit applications. Fact extraction MUST be explicit: if the user states a fact, call this tool in the same turn, never silently defer.",
        "tool_name": "profile_pipeline",
        "type": "tool_pipe",
        "uri": "http://localhost:5565",
        "name": "Pipeline Tool",
        "parameters": {
          "google": {}
        }
      },
      "ui": {
        "position": {
          "x": -70,
          "y": 350
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_chat"
        }
      ]
    },
    {
      "id": "tool_pipe_2",
      "provider": "tool_pipe",
      "name": "Scraping Pipeline Tool (match only)",
      "config": {
        "apikey": "MYAPIKEY",
        "pipe": "/Users/dylansavage/Desktop/RocketRide-Project/fun-dip/pipelines/scraping/pipeline.pipe",
        "return_type": "text",
        "tool_description": "Invoke the Fundip scraping pipeline in MATCH mode to score the existing 'programs' collection against a single profile and upsert rows into 'program_matches'. Input is fixed to { mode: 'match', profile_id: string, emit_callback: false }. You MAY NOT set mode='full_scrape' through this tool: full scraping is weekly-cron-only, owned by the app layer, and any such request will be rejected. The match path does not browse the web (no Tinyfish), it only re-scores what has already been scraped. Returns { status, mode: 'match', profile_id, matches: Array<{ program_match_id, program_id, score (0-100), tier ('hot'|'warm'|'cold'), positioning_summary (3-5 sentences) }> }. Call this when the user asks for fresh matches ('what do you have for me', 'rematch me', 're-rank programs') or right after a material profile fact has just been committed via profile_pipeline.",
        "tool_name": "scraping_pipeline_match",
        "type": "tool_pipe",
        "uri": "http://localhost:5565",
        "name": "Pipeline Tool",
        "parameters": {
          "google": {}
        }
      },
      "ui": {
        "position": {
          "x": 160,
          "y": 360
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_chat"
        }
      ]
    },
    {
      "id": "tool_pipe_3",
      "provider": "tool_pipe",
      "name": "Submissions Pipeline Tool",
      "config": {
        "apikey": "MYAPIKEY",
        "pipe": "/Users/dylansavage/Desktop/RocketRide-Project/fun-dip/pipelines/submissions/pipeline.pipe",
        "return_type": "text",
        "tool_description": "Invoke the Fundip submissions pipeline to prefill or submit an application for a (profile, program) pair. Input: { profile_id: string, program_id: string, submission_id?: string, action: 'prefill_only' | 'submit', provided_data?: Record<string, unknown> }. DEFAULT behavior is action='prefill_only': use it on the Programs page when the user says 'apply' against a selected program, and on the Submissions page when the user supplies values for a submission in 'awaiting_user_input' (pass them via provided_data along with the existing submission_id). action='submit' is ONLY permitted when the current user message contains explicit confirmation language ('yes submit', 'go ahead and submit', 'submit it', 'confirm submit'); inferred or stale consent is NEVER enough. The pipeline is idempotent: resubmitting an already-submitted row is a no-op. Returns one of { status: 'prefilled', submission_id, prefilled_fields } | { status: 'needs_input', submission_id, missing_fields } | { status: 'submitted', submission_id, confirmation_ref } | { status: 'error', submission_id, error, retryable }.",
        "tool_name": "submissions_pipeline",
        "type": "tool_pipe",
        "uri": "http://localhost:5565",
        "name": "Pipeline Tool",
        "parameters": {
          "google": {}
        }
      },
