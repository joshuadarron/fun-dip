          "x": 60,
          "y": 230
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "llm",
          "from": "agent_profile"
        }
      ]
    },
    {
      "id": "mcp_ghost",
      "provider": "mcp_client",
      "name": "MCP Client",
      "config": {
        "serverName": "ghost",
        "transport": "stdio",
        "type": "mcp_client",
        "stdio": {
          "commandLine": "/Users/dylansavage/.local/bin/ghost mcp start"
        },
        "http": {
          "bearer": "${ROCKETRIDE_GHOST_MCP_TOKEN}",
          "headers": {}
        },
        "parameters": {
          "google": {}
        }
      },
      "ui": {
        "position": {
          "x": 380,
          "y": 210
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_profile"
        }
      ]
    },
    {
