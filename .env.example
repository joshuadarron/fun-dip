# Fundip environment. Copy to .env and fill. Never commit .env.
# All keys consumed via apps/api/src/config/index.ts (zod-validated).

NODE_ENV=development
PORT=4000

# Absolute URL used to construct deep links.
APP_BASE_URL=http://localhost:3000

# Ghost MCP connection.
GHOST_MCP_URL=
GHOST_MCP_TOKEN=

# RocketRide SDK config for invoking pipelines.
ROCKETRIDE_API_URL=
ROCKETRIDE_API_KEY=

# HMAC secret for runtime-to-app callbacks (>= 32 chars).
CALLBACK_SHARED_SECRET=

# Signing key for email deep-link tokens (>= 32 chars).
DEEP_LINK_SIGNING_KEY=

# Resend (transactional email).
RESEND_API_KEY=

# Google OAuth.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
